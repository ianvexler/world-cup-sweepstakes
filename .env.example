# Copy to .env and fill in values:
#   cp .env.example .env

# Rails
RAILS_ENV=development

# Database (used by docker-compose backend + development/test in database.yml)
DATABASE_HOST=db
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=password
DATABASE_NAME=backend_development

# Required when RAILS_ENV=production (also satisfies database.yml at boot)
DATABASE_URL=postgres://postgres:password@db:5432/backend_development

# Auth
DEVISE_JWT_SECRET_KEY=dev_jwt_secret_only_for_local_docker_not_production_use_long_key

# football-data.org API (required for live match sync)
FOOTBALL_DATA_API_KEY=

# Bearer token for POST /api/v1/internal/matches/sync
INTERNAL_API_TOKEN=

# Optional: frontend API base URL (defaults to Vite /api proxy)
# VITE_BACKEND_URL=http://localhost:3000

# Optional: production CORS origins (comma-separated)
# CORS_ALLOWED_ORIGINS=https://your-frontend.example.com
